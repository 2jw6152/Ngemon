import type { SkillHandler } from '../runtime-api';

const handler: SkillHandler = (context, ops) => {
  const dealt = ops.dealDamage({{power}}{{#if accuracyDefined}}, {{accuracy}}{{/if}});
  if (dealt > 0) {
    ops.log(`${context.user.koName}의 {{name}}! ${dealt} 피해`);
  } else {
    ops.log(`${context.user.koName}의 {{name}}!`);
  }
};

export default handler;
